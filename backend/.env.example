# PORT
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/SEIRA

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Razorpay Keys
# Get these from https://dashboard.razorpay.com/app/website-setup/api-keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# GROQ API Key (for AIRed & Translation)
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (SMTP)
SMTP_HOST="YOUR_SMTP_HOST_HERE" # e.g., smtp.gmail.com or smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER="YOUR_EMAIL_OR_API_KEY_HERE"
SMTP_PASS="YOUR_PASSWORD_OR_API_SECRET_HERE"
